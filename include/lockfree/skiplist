        template <typename value_type_t>
        class malloc_backed_allocator
        {
        public:
            using value_type = value_type_t;

            value_type *allocate(size_t num_elements)
            {
                return static_cast<value_type *>(malloc(sizeof(value_type) * num_elements));
            }

            void deallocate(value_type *ptr, size_t /*num_elements*/)
            {
                free(ptr);
            }
        };
