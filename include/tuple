//  A couple of preprocessor defs to forward or simply get the value of a tuple element

#define _TUPLE_FWD_M(TupleType, BaseType, tup, value) static_cast<TupleType &&>(tup).BaseType::value
#define _TUPLE_GET_M(BaseType, tup, value) tup.BaseType::value

