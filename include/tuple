    //
    //  Conversion
    //

    // Converts from one tuple type to any other tuple or U

    template <class Tuple>
    struct convert
    {
        using base_list = typename decay_t<Tuple>::base_list;
        Tuple tuple;
        template <class U>
        constexpr operator U() &&
        {
            return tuple_internal::detail::_convert<U>(
                static_cast<Tuple &&>(tuple),
                base_list{});
        }
    };

    template <class Tuple>
    convert(Tuple &) -> convert<Tuple &>;

    template <class Tuple>
    convert(Tuple const &) -> convert<Tuple const &>;

    template <class Tuple>
    convert(Tuple &&) -> convert<Tuple>;

    //
    //  tuplet Appendix 1: Small non-member functions
    //

    //
    // get, tie, apply, swap, make_tuple, forward_as_tuple
    //

    template <size_t I, indexable Tup>
    inline constexpr decltype(auto) get(Tup &&tup)
    {
        return static_cast<Tup &&>(tup)[tag<I>()];
    }

    template <class... T>
    inline constexpr tuple<T &...> tie(T &...t)
    {
        return {t...};
    }

    template <class F, base_list_tuple Tup>
    inline constexpr decltype(auto) apply(F &&func, Tup &&tup)
    {
        return tuple_internal::detail::_apply(
            static_cast<Tup &&>(tup),
            static_cast<F &&>(func),
            typename decay_t<Tup>::base_list{});
    }

    template <class... T>
    inline void swap(tuple<T...> &a, tuple<T...> &b) noexcept(tuple<T...>::nothrow_swappable)
    {
        a.swap(b);
    }

    template <typename... Ts>
    inline constexpr auto make_tuple(Ts &&...args)
    {
        return tuple<unwrap_ref_decay_t<Ts>...>{static_cast<Ts &&>(args)...};
    }

    template <typename... T>
    inline constexpr auto forward_as_tuple(T &&...a) noexcept
    {
        return tuple<T &&...>{static_cast<T &&>(a)...};
    }

    //
    //  Appendix 2: The Horror that is tuple_cat
    //

    namespace tuple_internal::detail
    {
        template <class T, class... Q>
        inline constexpr auto _repeat_type(type_list<Q...>)
        {
            return type_list<first_t<T, Q>...>{};
        }
        template <class... Outer>
        inline constexpr auto _get_outer_bases(type_list<Outer...>)
        {
            return (_repeat_type<Outer>(base_list_t<type_t<Outer>>{}) + ...);
        }
        template <class... Outer>
        inline constexpr auto _get_inner_bases(type_list<Outer...>)
        {
            return (base_list_t<type_t<Outer>>{} + ...);
        }

        // This takes a forwarding tuple as a parameter. The forwarding tuple only
        // contains references, so it should just be taken by value.

        template <class T, class... Outer, class... Inner>
        inline constexpr auto _tuple_cat(
            T tup,
            type_list<Outer...>,
            type_list<Inner...>) -> tuple<type_t<Inner>...>
        {
            return {_TUPLE_FWD_M(
                type_t<Outer>,
                Inner,
                _TUPLE_GET_M(Outer, tup, value),
                value)...};
        }
    } // namespace tuple_internal::detail

    template <base_list_tuple... T>
    constexpr auto tuple_cat(T &&...ts)
    {
        if constexpr (sizeof...(T) == 0)
        {
            return tuple<>();
        }
        else
        {
            using big_tuple = tuple<T &&...>;

            using outer_bases = base_list_t<big_tuple>;
            constexpr auto outer = tuple_internal::detail::_get_outer_bases(outer_bases{});
            constexpr auto inner = tuple_internal::detail::_get_inner_bases(outer_bases{});
            return tuple_internal::detail::_tuple_cat(
                big_tuple{static_cast<T &&>(ts)...},
                outer,
                inner);
        }
    }

    //
    //  Appendix 3: tag literals
    //

    namespace tuple_internal::literals
    {
        template <char... D>
        constexpr size_t _size_t_from_digits()
        {
            static_assert(
                (('0' <= D && D <= '9') && ...),
                "Must be integral literal");
            size_t num = 0;
            return ((num = num * 10 + (D - '0')), ..., num);
        }
    } // namespace tuple_internal::literals::detail

    inline namespace literals
    {
        inline namespace tuple_literals
        {
            template <char... D>
            constexpr auto operator""_tag() noexcept
                -> tag<tuple_internal::literals::_size_t_from_digits<D...>()>
            {
                return {};
            }
        } // namespace tuple
    } // namespace literals
