    template <class T>
    struct unwrap_reference
    {
        using type = T;
    };

    template <class U>
    struct unwrap_reference<reference_wrapper<U>>
    {
        using type = U &;
    };

    template <class T>
    struct unwrap_ref_decay : unwrap_reference<decay_t<T>>
    {
    };

    template <class T>
    using unwrap_ref_decay_t = typename unwrap_ref_decay<T>::type;

    template <class T>
    using identity_t = T;

    /// Takes a type B, and gives it the same "rvalue" status as Tup
    /// Used for forwarding values out of a tuple
    template <class Tup, class B>
    using forward_as_t = typename tuple_internal::detail::_forward_as<Tup, B>::type;

    template <class First, class...>
    using first_t = First;

    // Obtains T::type
    template <class T>
    using type_t = typename T::type;

    template <size_t I>
    using tag = integral_constant<size_t, I>;

    template <size_t I>
    constexpr tag<I> tag_v{};

    template <size_t N>
    using tag_range = make_index_sequence<N>;

    template <class Tup>
    using base_list_t = typename decay_t<Tup>::base_list;
    template <class Tup>
    using element_list_t = typename decay_t<Tup>::element_list;

    template <class T>
    constexpr bool stateless_v = is_empty_v<decay_t<T>>;

    template <class T, class U>
    concept other_than = !is_same_v<decay_t<T>, decay_t<U>>;

    template <class Tuple>
    concept base_list_tuple = requires() {
        typename decay_t<Tuple>::base_list;
    };

    template <class T>
    concept stateless = is_empty_v<decay_t<T>>;

    template <class T>
    concept indexable = stateless<T> || requires(T t) { t[tag<0>()]; };

    template <class U, class T>
    concept assignable_to = requires(U u, T t) { t = u; };

    template <class T>
    concept partial_comparable = equality_comparable<T> && requires(T const &t) {
        { t < t } -> same_as<bool>;
    };
    template <class T, class U>
    concept partial_comparable_with = equality_comparable_with<T, U> && requires(T const &t, U const &u) {
        { t < u } -> same_as<bool>;
        { t > u } -> same_as<bool>;
    };

    template <class Tuple>
    constexpr auto base_list_tuple_v = base_list_tuple<Tuple>;

    //
    //  Comparison Operator Helpers
    //

    namespace tuple_internal::detail
    {
        // Computes a partial comparison. Returns true iff a == b. Otherwise, sets less to true if a < b

        template <class T, class U>
        inline constexpr bool _partial_cmp(
            T const &a,
            U const &b,
            bool &less)
        {
            if constexpr (tuple_internal::sfinae::detail::_test_m_compare<T, U>(0))
            {
                int cmp = a.compare(b);

                if (cmp < 0)
                {
                    less = true;
                }
                return cmp == 0;
            }
            else
            {
                if constexpr (partial_comparable_with<T, U>)
                {
                    if (a < b)
                    {
                        less = true;
                        return false;
                    }
                    if (a > b)
                    {
                        return false;
                    }
                    return a == b;
                }
                else
                {
                    if (a < b)
                    {
                        less = true;
                        return false;
                    }
                    else
                    {
                        return a == b;
                    }
                }
            }
        }

        template <class Tup, class... B1>
        inline constexpr bool _equals(
            Tup const &t1,
            Tup const &t2,
            type_list<B1...>)
        {
            return (
                (_TUPLE_GET_M(B1, t1, value) == _TUPLE_GET_M(B1, t2, value)) && ...);
        }

        template <class Tup, class... B1>
        inline constexpr bool _less(
            Tup const &t1,
            Tup const &t2,
            type_list<B1...>)
        {
            bool is_less = false;

            (_partial_cmp(
                 _TUPLE_GET_M(B1, t1, value),
                 _TUPLE_GET_M(B1, t2, value),
                 is_less) &&
             ...);

            return is_less;
        }

        template <class Tup, class... B1>
        inline constexpr bool _less_eq(
            Tup const &t1,
            Tup const &t2,
            type_list<B1...>)
        {
            bool is_less = false;

            bool is_eq =
                (_partial_cmp(
                     _TUPLE_GET_M(B1, t1, value),
                     _TUPLE_GET_M(B1, t2, value),
                     is_less) &&
                 ... && true);

            return is_less || is_eq;
        }

        template <class Tup1, class Tup2, class... B1, class... B2>
        inline constexpr bool _equals(
            Tup1 const &t1,
            Tup2 const &t2,
            type_list<B1...>,
            type_list<B2...>)
        {

            return ((_TUPLE_GET_M(B1, t1, value) == _TUPLE_GET_M(B2, t2, value)) && ...);
        }

        template <class Tup1, class Tup2, class... B1, class... B2>
        inline constexpr bool _less(
            Tup1 const &t1,
            Tup2 const &t2,
            type_list<B1...>,
            type_list<B2...>)
        {
            bool is_less = false;

            (_partial_cmp(_TUPLE_GET_M(B1, t1, value),
                          _TUPLE_GET_M(B2, t2, value),
                          is_less) &&
             ... && true);

            return is_less;
        }

        template <class Tup1, class Tup2, class... B1, class... B2>
        inline constexpr bool _less_eq(
            Tup1 const &t1,
            Tup2 const &t2,
            type_list<B1...>,
            type_list<B2...>)
        {
            bool is_less = false;

            bool is_eq = (_partial_cmp(
                              _TUPLE_GET_M(B1, t1, value),
                              _TUPLE_GET_M(B2, t2, value),
                              is_less) &&
                          ... && true);

            return is_less || is_eq;
        }
    } // namespace tuple_internal::detail

    //
    //  type_map
    //

    template <class... Bases>
    struct type_map : Bases...
    {
        using base_list = type_list<Bases...>;
        using Bases::operator[]...;
        using Bases::decl_elem...;
    };

    //
    //  tuple_elem
    //

    template <size_t I, class T>
    struct tuple_elem
    {
        // Like declval, but with the element
        static T decl_elem(tag<I>);
        using type = T;

        [[no_unique_address]] T value;

        inline constexpr decltype(auto) operator[](tag<I>) &
        {
            return (value);
        }

        inline constexpr decltype(auto) operator[](tag<I>) const &
        {
            return (value);
        }

        inline constexpr decltype(auto) operator[](tag<I>) &&
        {
            return (static_cast<tuple_elem &&>(*this).value);
        }

        //  Intentionally no defaulted or custom comparison operators to avoid
        //  compiler-specific issues with <=> and comparison category types.
    };

    //
    //  tuple_base_t - Base class for tuple
    //

    namespace tuple_internal::detail
    {
        template <class IndexSequence, class... T>
        struct _get_tuple_base;

        template <size_t... I, class... T>
        struct _get_tuple_base<index_sequence<I...>, T...>
        {
            using type = type_map<tuple_elem<I, T>...>;
        };
    } // namespace tuple_internal::detail

    /// Obtains a tuplet::type_map whose bases correspond to
    /// tuplet::tuple_elem<I, T>. Used as the base class for tuplet::tuple.
    template <class... T>
    using tuple_base_t = typename tuple_internal::detail::_get_tuple_base<tag_range<sizeof...(T)>, T...>::type;

    //
    //  tuple Implementation Details
    //

    template <class... T>
    struct tuple;

    namespace tuple_internal::detail
    {
        template <class Tup, class F, class... B>
        inline constexpr void _for_each(
            Tup &&tup,
            F &&func,
            type_list<B...>)
        {
            (void(func(_TUPLE_FWD_M(Tup, B, tup, value))), ...);
        }

        template <class Tup, class F, class... B>
        inline constexpr bool _any(Tup &&tup, F &&func, type_list<B...>)
        {
            return (bool(func(_TUPLE_FWD_M(Tup, B, tup, value))) || ...);
        }

        template <class Tup, class F, class... B>
        inline constexpr bool _all(Tup &&tup, F &&func, type_list<B...>)
        {
            return (bool(func(_TUPLE_FWD_M(Tup, B, tup, value))) && ...);
        }

        template <class Tup, class F, class... B>
        inline constexpr auto _map(Tup &&tup, F &&func, type_list<B...>) -> tuple<decltype(func(_TUPLE_FWD_M(Tup, B, tup, value)))...>
        {
            return {func(_TUPLE_FWD_M(Tup, B, tup, value))...};
        }

        template <class Tup, class F, class... B>
        inline constexpr decltype(auto) _apply(
            Tup &&t,
            F &&f,
            type_list<B...>)
        {
            return static_cast<F &&>(f)(_TUPLE_FWD_M(Tup, B, t, value)...);
        }

        template <class U, class Tup, class... B>
        inline constexpr U _convert(Tup &&t, type_list<B...>)
        {
            return U{_TUPLE_FWD_M(Tup, B, t, value)...};
        }
    } // namespace tuple_internal::detail

    //
    //  tuple Primary Implementation
    //

    template <class... T>
    struct tuple : tuple_base_t<T...>
    {
        constexpr static size_t N = sizeof...(T);
        constexpr static bool nothrow_swappable = (is_nothrow_swappable_v<T> && ...);
        using super = tuple_base_t<T...>;
        using super::operator[];
        using base_list = typename super::base_list;
        using element_list = type_list<T...>;
        using super::decl_elem;

        template <other_than<tuple> U> // Preserves default assignments
        inline constexpr auto &operator=(U &&tup)
        {
            using tuple2 = decay_t<U>;
            if constexpr (base_list_tuple_v<tuple2>)
            {
                _assign_tup(
                    static_cast<U &&>(tup),
                    base_list{},
                    typename tuple2::base_list{});
            }
            else
            {
                _assign_index_tup(static_cast<U &&>(tup), tag_range<N>());
            }
            return *this;
        }

        template <class... U>
            requires(assignable_to<U, T> && ...)
        constexpr auto &assign(U &&...values)
        {
            _assign(base_list{}, static_cast<U &&>(values)...);
            return *this;
        }

        template <class... U>
        inline constexpr auto operator==(tuple<U...> const &other) const -> bool
            requires(equality_comparable_with<T, U> && ...)
        {
            using other_base_list = typename tuple<U...>::base_list;
            return tuple_internal::detail::_equals(
                *this,
                other,
                base_list{},
                other_base_list{});
        }

        template <class... U>
        inline constexpr auto operator!=(tuple<U...> const &other) const -> bool
            requires(equality_comparable_with<T, U> && ...)
        {
            return !(*this == other);
        }

        template <class... U>
        inline constexpr auto operator<(tuple<U...> const &other) const -> bool
            requires(equality_comparable_with<T, U> && ...)
        {
            using other_base_list = typename tuple<U...>::base_list;
            return tuple_internal::detail::_less(
                *this,
                other,
                base_list{},
                other_base_list{});
        }

        template <class... U>
        inline constexpr auto operator<=(tuple<U...> const &other) const -> bool
            requires(equality_comparable_with<T, U> && ...)
        {
            using other_base_list = typename tuple<U...>::base_list;
            return tuple_internal::detail::_less_eq(
                *this,
                other,
                base_list{},
                other_base_list{});
        }

        template <class... U>
        inline constexpr auto operator>(tuple<U...> const &other) const -> bool
            requires(equality_comparable_with<T, U> && ...)
        {
            using other_base_list = typename tuple<U...>::base_list;
            return tuple_internal::detail::_less(
                other,
                *this,
                other_base_list{},
                base_list{});
        }

        template <class... U>
        inline constexpr auto operator>=(tuple<U...> const &other) const -> bool
            requires(equality_comparable_with<T, U> && ...)
        {
            using other_base_list = typename tuple<U...>::base_list;
            return tuple_internal::detail::_less_eq(
                other,
                *this,
                other_base_list{},
                base_list{});
        }

        inline constexpr void swap(tuple &other) noexcept(nothrow_swappable)
        {
            _swap(other, base_list{});
        }

        // Applies a function to every element of the tuple. The order is the
        // declaration order, so first the function will be applied to element
        // 0, then element 1, then element 2, and so on, where element N is
        // identified by get<N>

        template <class F>
        inline constexpr void for_each(F &&func) &
        {
            tuple_internal::detail::_for_each(*this, static_cast<F &&>(func), base_list{});
        }

        template <class F>
        inline constexpr void for_each(F &&func) const &
        {
            tuple_internal::detail::_for_each(*this, static_cast<F &&>(func), base_list{});
        }

        template <class F>
        inline constexpr void for_each(F &&func) &&
        {
            tuple_internal::detail::_for_each(
                static_cast<tuple &&>(*this),
                static_cast<F &&>(func),
                base_list{});
        }

        // Applies a function to each element successively, until one returns a
        // truthy value. Returns true if any application returned a truthy
        // value, and false otherwise

        template <class F>
        inline constexpr bool any(F &&func) &
        {
            return tuple_internal::detail::_any(*this, static_cast<F &&>(func), base_list{});
        }

        template <class F>
        inline constexpr bool any(F &&func) const &
        {
            return tuple_internal::detail::_any(*this, static_cast<F &&>(func), base_list{});
        }

        template <class F>
        inline constexpr bool any(F &&func) &&
        {
            return tuple_internal::detail::_any(
                static_cast<tuple &&>(*this),
                static_cast<F &&>(func),
                base_list{});
        }

        // Applies a function to each element successively, until one returns a
        // falsy value. Returns true if every application returned a truthy
        // value, and false otherwise

        template <class F>
        inline constexpr bool all(F &&func) &
        {
            return tuple_internal::detail::_all(*this, static_cast<F &&>(func), base_list{});
        }

        template <class F>
        inline constexpr bool all(F &&func) const &
        {
            return tuple_internal::detail::_all(*this, static_cast<F &&>(func), base_list{});
        }

        template <class F>
        inline constexpr bool all(F &&func) &&
        {
            return tuple_internal::detail::_all(
                static_cast<tuple &&>(*this),
                static_cast<F &&>(func),
                base_list{});
        }

        // Map a function over every element in the tuple, using the values to
        // construct a new tuple

        template <class F>
        inline constexpr auto map(F &&func) &
        {
            return tuple_internal::detail::_map(*this, static_cast<F &&>(func), base_list{});
        }

        template <class F>
        inline constexpr auto map(F &&func) const &
        {
            return tuple_internal::detail::_map(*this, static_cast<F &&>(func), base_list{});
        }

        template <class F>
        inline constexpr auto map(F &&func) &&
        {
            return tuple_internal::detail::_map(
                static_cast<tuple &&>(*this),
                static_cast<F &&>(func),
                base_list{});
        }

        template <class F>
        inline constexpr decltype(auto) apply(F &&func) &
        {
            return tuple_internal::detail::_apply(*this, static_cast<F &&>(func), base_list{});
        }

        template <class F>
        inline constexpr decltype(auto) apply(F &&func) const &
        {
            return tuple_internal::detail::_apply(*this, static_cast<F &&>(func), base_list{});
        }

        template <class F>
        inline constexpr decltype(auto) apply(F &&func) &&
        {
            return tuple_internal::detail::_apply(
                static_cast<tuple &&>(*this),
                static_cast<F &&>(func),
                base_list{});
        }

        template <class... U>
        constexpr explicit operator tuple<U...>() &
        {
            static_assert(
                sizeof...(U) == N,
                "Can only convert to tuples with the same number of items");
            return tuple_internal::detail::_convert<tuple<U...>>(*this, base_list{});
        }

        template <class... U>
        constexpr explicit operator tuple<U...>() const &
        {
            static_assert(
                sizeof...(U) == N,
                "Can only convert to tuples with the same number of items");
            return tuple_internal::detail::_convert<tuple<U...>>(*this, base_list{});
        }

        template <class... U>
        constexpr explicit operator tuple<U...>() &&
        {
            static_assert(
                sizeof...(U) == N,
                "Can only convert to tuples with the same number of items");
            return tuple_internal::detail::_convert<tuple<U...>>(
                static_cast<tuple &&>(*this),
                base_list{});
        }

        // Instantiate the given type using list initialization

        template <class U>
        inline constexpr U as() &
        {
            return tuple_internal::detail::_convert<U>(*this, base_list{});
        }

        // Instantiate the given type using list initialization
        template <class U>
        inline constexpr U as() const &
        {
            return tuple_internal::detail::_convert<U>(*this, base_list{});
        }

        // Instantiate the given type using list initialization

        template <class U>
        inline constexpr U as() &&
        {
            return tuple_internal::detail::_convert<U>(
                static_cast<tuple &&>(*this),
                base_list{});
        }

    private:
        template <class... B>
        inline constexpr void _swap(
            tuple &other,
            type_list<B...>) noexcept(nothrow_swappable)
        {
            (MINIMAL_STD_NAMESPACE::swap(B::value, _TUPLE_GET_M(B, other, value)), ...);
        }

        template <class U, class... B1, class... B2>
        inline constexpr void _assign_tup(
            U &&u,
            type_list<B1...>,
            type_list<B2...>)
        {
            (void(B1::value = _TUPLE_FWD_M(U, B2, u, value)), ...);
        }

        template <class U, size_t... I>
        inline constexpr void _assign_index_tup(
            U &&u,
            index_sequence<I...>)
        {
            (void(tuple_elem<I, T>::value = get<I>(static_cast<U &&>(u))), ...);
        }

        template <class... U, class... B>
        inline constexpr void _assign(type_list<B...>, U &&...u)
        {
            (void(B::value = static_cast<U &&>(u)), ...);
        }
    };

    //
    //  tuple Empty Tuple Specialization
    //

    template <>
    struct tuple<> : tuple_base_t<>
    {
        constexpr static size_t N = 0;
        constexpr static bool nothrow_swappable = true;
        using super = tuple_base_t<>;
        using base_list = type_list<>;
        using element_list = type_list<>;

        template <other_than<tuple> U> // Preserves default assignments
            requires stateless<U>      // Insure U is stateless
        constexpr auto &
        operator=(U &&) noexcept
        {
            return *this;
        }

        constexpr void swap(tuple) noexcept {}
        constexpr auto &assign() noexcept { return *this; }

        inline constexpr bool operator==(tuple const &) const noexcept
        {
            return true;
        }

        inline constexpr bool operator!=(tuple const &) const noexcept
        {
            return false;
        }

        inline constexpr bool operator<(tuple const &) const noexcept
        {
            return false;
        }

        inline constexpr bool operator>(tuple const &) const noexcept
        {
            return false;
        }

        inline constexpr bool operator<=(tuple const &) const noexcept
        {
            return true;
        }

        inline constexpr bool operator>=(tuple const &) const noexcept
        {
            return true;
        }

        // Applies a function to every element of the tuple. The order is the
        // declaration order, so first the function will be applied to element
        // 0, then element 1, then element 2, and so on, where element N is
        // identified by get<N>
        //
        // (Does nothing when invoked on empty tuple)

        template <class F>
        constexpr void for_each(F &&) const noexcept {}

        // Applies a function to each element successively, until one returns a
        // truthy value. Returns true if any application returned a truthy
        // value, and false otherwise
        //
        // (Returns false for empty tuple)

        template <class F>
        constexpr bool any(F &&) const noexcept
        {
            return false;
        }

        // Applies a function to each element successively, until one returns a
        // falsy value. Returns true if every application returned a truthy
        // value, and false otherwise
        //
        // (Returns true for empty tuple)

        template <class F>
        constexpr bool all(F &&) const noexcept
        {
            return true;
        }

        // Map a function over every element in the tuple, using the values to
        // construct a new tuple
        //
        // (Returns empty tuple when invoked on empty tuple)

        template <class F>
        constexpr auto map(F &&) const noexcept
        {
            return tuple{};
        }

        template <class F>
        constexpr decltype(auto) apply(F &&func) const noexcept
        {
            return func();
        }

        template <class U>
        constexpr U as() const noexcept
        {
            return U{};
        }
    };

    template <class... Ts>
    tuple(Ts...) -> tuple<unwrap_ref_decay_t<Ts>...>;

