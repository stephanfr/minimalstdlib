#pragma once

#include "minstdconfig.h"

#include "new"
#include "type_traits"
#include <stddef.h>

#include "utility"

namespace MINIMAL_STD_NAMESPACE
{
    struct nullopt_t
    {
        explicit constexpr nullopt_t(int) noexcept {}
    };

    inline constexpr nullopt_t nullopt{0};

    template <typename T>
    class optional
    {
    public:
        optional()
            : has_value_(false),
              dummy_(0)
        {
        }

        optional(const optional &optional_to_copy)
            : has_value_(false),
              dummy_(0)
        {
            if (optional_to_copy.has_value_)
            {
                construct_value(optional_to_copy.value_);
            }
        }

        optional(optional &&optional_to_copy)
            : has_value_(false),
              dummy_(0)
        {
            if (optional_to_copy.has_value_)
            {
                construct_value(minstd::move(optional_to_copy.value_));
            }
        }

        optional(nullopt_t) noexcept
            : has_value_(false),
              dummy_(0)
        {
        }

        optional(const T &value)
            : has_value_(false),
              dummy_(0)
        {
            construct_value(value);
        }

        template <class... Args, enable_if_t<is_constructible_v<T, Args...>, int> = 0>
        explicit optional(Args &&...args)
            : has_value_(true)
        {
            new (&value_) T(minstd::forward<Args>(args)...);
        }

        ~optional()
        {
            destroy_value();
        }

        optional& operator=( const T &new_value )
        {
            if (has_value_)
            {
                value_ = new_value;
            }
            else
            {
                construct_value(new_value);
            }

            return *this;
        }

        optional& operator=(nullopt_t) noexcept
        {
            reset();
            return *this;
        }

        optional& operator=( const optional &optional_to_copy )
        {
            if (this == &optional_to_copy)
            {
                return *this;
            }

            if (optional_to_copy.has_value_)
            {
                if (has_value_)
                {
                    value_ = optional_to_copy.value_;
                }
                else
                {
                    construct_value(optional_to_copy.value_);
                }
            }
            else
            {
                destroy_value();
            }

            return *this;
        }

        optional& operator=( optional &&optional_to_move )
        {
            if (this == &optional_to_move)
            {
                return *this;
            }

            if (optional_to_move.has_value_)
            {
                if (has_value_)
                {
                    value_ = minstd::move(optional_to_move.value_);
                }
                else
                {
                    construct_value(minstd::move(optional_to_move.value_));
                }
            }
            else
            {
                destroy_value();
            }

            return *this;
        }

        void reset()
        {
            destroy_value();
        }

        template <class... Args>
        T &emplace(Args &&...args)
        {
            destroy_value();
            new (&value_) T(minstd::forward<Args>(args)...);
            has_value_ = true;
            return value_;
        }

        template <typename U>
        T value_or(U &&default_value) const
        {
            if (has_value_)
            {
                return value_;
            }
            return static_cast<T>(minstd::forward<U>(default_value));
        }

        constexpr bool has_value() const noexcept
        {
            return has_value_;
        }

        T &operator*()
        {
            return value_;
        }

        const T &operator*() const
        {
            return value_;
        }

        T *operator->()
        {
            return &(value_);
        }

        const T *operator->() const
        {
            return &(value_);
        }

        T &value()
        {
            if (!has_value_)
            {
                __builtin_trap();
            }
            return value_;
        }

        const T &value() const
        {
            if (!has_value_)
            {
                __builtin_trap();
            }
            return value_;
        }

    private:
        void destroy_value()
        {
            if (has_value_)
            {
                (&value_)->~T();
                has_value_ = false;
            }
        }

        template <typename U>
        void construct_value(U &&value)
        {
            new (&value_) T(minstd::forward<U>(value));
            has_value_ = true;
        }

        bool has_value_;
        union
        {
            char dummy_;
            T value_;
        };
    };

    template <typename T>
    bool operator==(const optional<T> &lhs, const optional<T> &rhs)
    {
        if (lhs.has_value() != rhs.has_value())
        {
            return false;
        }
        if (!lhs.has_value())
        {
            return true;
        }
        return *lhs == *rhs;
    }

    template <typename T>
    bool operator!=(const optional<T> &lhs, const optional<T> &rhs)
    {
        return !(lhs == rhs);
    }

    template <typename T>
    bool operator==(const optional<T> &lhs, const T &rhs)
    {
        return lhs.has_value() && *lhs == rhs;
    }

    template <typename T>
    bool operator!=(const optional<T> &lhs, const T &rhs)
    {
        return !(lhs == rhs);
    }

    template <typename T>
    bool operator==(const T &lhs, const optional<T> &rhs)
    {
        return rhs.has_value() && lhs == *rhs;
    }

    template <typename T>
    bool operator!=(const T &lhs, const optional<T> &rhs)
    {
        return !(lhs == rhs);
    }

    template <typename T>
    bool operator==(const optional<T> &lhs, nullopt_t) noexcept
    {
        return !lhs.has_value();
    }

    template <typename T>
    bool operator!=(const optional<T> &lhs, nullopt_t) noexcept
    {
        return lhs.has_value();
    }

    template <typename T>
    bool operator==(nullopt_t, const optional<T> &rhs) noexcept
    {
        return !rhs.has_value();
    }

    template <typename T>
    bool operator!=(nullopt_t, const optional<T> &rhs) noexcept
    {
        return rhs.has_value();
    }

}
