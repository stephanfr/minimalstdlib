#pragma GCC diagnostic ignored "-Wliteral-suffix"
    inline namespace literals
    {
        inline namespace chrono_literals
        {
            constexpr chrono::nanoseconds operator"" ns(unsigned long long nanoseconds)
            {
                return chrono::nanoseconds(nanoseconds);
            }

            constexpr chrono::duration<long double, nano> operator"" ns(long double nanoseconds)
            {
                return chrono::duration<long double, nano>(nanoseconds);
            }

            constexpr chrono::microseconds operator"" us(unsigned long long microseconds)
            {
                return chrono::microseconds(microseconds);
            }

            constexpr chrono::duration<long double, micro> operator"" us(long double microseconds)
            {
                return chrono::duration<long double, micro>(microseconds);
            }

            constexpr chrono::milliseconds operator"" ms(unsigned long long milliseconds)
            {
                return chrono::milliseconds(milliseconds);
            }

            constexpr chrono::duration<long double, milli> operator"" ms(long double milliseconds)
            {
                return chrono::duration<long double, milli>(milliseconds);
            }

            constexpr chrono::seconds operator"" s(unsigned long long seconds)
            {
                return chrono::seconds(seconds);
            }

            constexpr chrono::duration<long double> operator"" s(long double seconds)
            {
                return chrono::duration<long double>(seconds);
            }

            constexpr chrono::minutes operator"" min(unsigned long long minutes)
            {
                return chrono::minutes(minutes);
            }

            constexpr chrono::duration<long double, ratio<60>> operator"" min(long double minutes)
            {
                return chrono::duration<long double, ratio<60>>(minutes);
            }

            constexpr chrono::hours operator"" h(unsigned long long hours)
            {
                return chrono::hours(hours);
            }

            constexpr chrono::duration<long double, ratio<3600>> operator"" h(long double hours)
            {
                return chrono::duration<long double, ratio<3600>>(hours);
            }
        }
    }
