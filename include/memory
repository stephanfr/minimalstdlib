#pragma once

#include <stddef.h>

#include <alloca.h>

#include "new"

#include "minstdconfig.h"
#include "utility"

#include "__memory_resource/memory_resource.h"

namespace MINIMAL_STD_NAMESPACE
{

    template <typename T>
    class unique_ptr
    {
    public:
        explicit unique_ptr()
        {
        }

        explicit unique_ptr(T *pointer_to_wrap, minstd::pmr::memory_resource &resource)
            : wrapped_pointer_(pointer_to_wrap),
              resource_(&resource)
        {
        }

        unique_ptr(unique_ptr &pointer_to_copy)
            : wrapped_pointer_(pointer_to_copy.wrapped_pointer_),
              resource_(pointer_to_copy.resource_)
        {
            pointer_to_copy.wrapped_pointer_ = nullptr;
        }

        unique_ptr(unique_ptr &&pointer_to_copy)
            : wrapped_pointer_(pointer_to_copy.wrapped_pointer_),
              resource_(pointer_to_copy.resource_)
        {
            pointer_to_copy.wrapped_pointer_ = nullptr;
        }

        ~unique_ptr()
        {
            destroy_wrapped_pointer();
        }

        unique_ptr &operator=(unique_ptr &pointer_to_copy) = delete;

        unique_ptr &operator=(unique_ptr &&pointer_to_move)
        {
            destroy_wrapped_pointer();

            wrapped_pointer_ = pointer_to_move.wrapped_pointer_;
            resource_ = pointer_to_move.resource_;
            pointer_to_move.wrapped_pointer_ = nullptr;

            return *this;
        }

        operator bool() const
        {
            return wrapped_pointer_ != nullptr;
        }

        T &operator*()
        {
            return *wrapped_pointer_;
        }

        const T &operator*() const
        {
            return *wrapped_pointer_;
        }

        T *operator->()
        {
            return wrapped_pointer_;
        }

        const T *operator->() const
        {
            return wrapped_pointer_;
        }

        T *release() noexcept
        {
            T *return_value = wrapped_pointer_;

            wrapped_pointer_ = nullptr;

            return return_value;
        }

        T *get() const noexcept
        {
            return wrapped_pointer_;
        }

    private:
        void destroy_wrapped_pointer()
        {
            if (wrapped_pointer_ == nullptr)
            {
                return;
            }

            wrapped_pointer_->~T();

            if (resource_ != nullptr)
            {
                resource_->deallocate(wrapped_pointer_, sizeof(T), alignof(T));
            }

            wrapped_pointer_ = nullptr;
        }

        T *wrapped_pointer_ = nullptr;
        minstd::pmr::memory_resource *resource_ = nullptr;
    };
}   //  namespace MINSTD
